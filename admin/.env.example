# Frontend (Vite) — sve VITE_ varijable su public i idu u bundle
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Stripe publishable (pk_live_...) — safe za frontend, ali ne commituj stvarni u public repo
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME

# Test publishable (pk_test_...) — koristi se kad je Stripe mode toggle na "test".
# Ako nije postavljen, test mod neće raditi (toggle će biti vidljiv ali Stripe neće učitati).
VITE_STRIPE_PUBLISHABLE_KEY_TEST=pk_test_REPLACE_ME
